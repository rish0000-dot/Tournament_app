# ================================
# BLAZESTRIKE BACKEND CONFIG
# ================================

# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=blazestrike
DB_USER=postgres
DB_PASSWORD=your_db_password

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=30d

# Razorpay (Payment Gateway)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Razorpay Payouts (Withdrawals)
RAZORPAY_PAYOUT_KEY=rzp_payout_xxxxxxxxxxxxx
RAZORPAY_ACCOUNT_NUMBER=XXXXXXXXXXXXXXXX

# AWS S3 (Screenshot Storage)
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=ap-south-1
AWS_S3_BUCKET=blazestrike-screenshots

# SMS OTP (Fast2SMS)
FAST2SMS_API_KEY=your_fast2sms_api_key

# Google Cloud Vision (OCR for screenshots)
GOOGLE_CLOUD_KEY=your_google_cloud_api_key

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=blazestrike-app
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@blazestrike.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXX\n-----END PRIVATE KEY-----"

# App Config
OTP_EXPIRY_MINUTES=10
COIN_TO_RUPEE_RATE=100
MIN_WITHDRAWAL=10
MAX_WITHDRAWAL_DAILY=100000
STREAK_MULTIPLIER_2=1.5
STREAK_MULTIPLIER_3=2
STREAK_MULTIPLIER_5=3
STREAK_MULTIPLIER_10=5
COIN_EXPIRY_DAYS=45
